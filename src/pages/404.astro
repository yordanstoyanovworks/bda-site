---
import Base from '../layouts/Base.astro';
---

<Base title="404 - Страницата не е намерена">
  <section class="not-found">
    <div class="container">
      <p class="code">404</p>
      <h1>Страницата не съществува.</h1>
      <p class="message">
        Възможно е линкът да е остарял или агенцията да е премахната от каталога.
      </p>
      <a href="/" class="back-link">← Обратно към началото</a>
    </div>
  </section>
</Base>

<style>
  .not-found {
    padding: 5rem 0 6rem;
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .code {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--grey-500);
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
  }

  h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    max-width: 520px;
  }

  .message {
    margin-top: 1rem;
    font-size: 0.9375rem;
    color: var(--grey-700);
    line-height: 1.6;
    max-width: 480px;
  }

  .back-link {
    display: inline-block;
    margin-top: 2rem;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.625rem 1rem;
    background: var(--black);
    color: var(--white);
    border-radius: 6px;
    transition: opacity 0.15s;
  }

  .back-link:hover {
    opacity: 0.8;
  }
</style>
