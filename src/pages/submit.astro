---
import Base from '../layouts/Base.astro';
---

<Base title="Предложи Агенция - BDA">
  <section class="submit">
    <div class="container">
      <h1>Предложете дизайн агенция</h1>
      <p class="note">Запазвам правото си да не публикувам всички изпратени предложения.</p>

      <form class="form" id="submit-form">
        <div class="field">
          <label for="name">Име на агенцията</label>
          <input type="text" id="name" name="name" placeholder="Въведете име..." required />
        </div>
        <div class="field">
          <label for="website">Линк към уебсайта</label>
          <input type="url" id="website" name="website" placeholder="https://..." required />
        </div>
        <div class="field">
          <label for="services">Предлагани услуги</label>
          <input type="text" id="services" name="services" placeholder="Напр. Брандинг, Уеб Дизайн..." />
        </div>
        <div class="field">
          <label for="email">Ваш имейл за обратна връзка</label>
          <input type="email" id="email" name="email" placeholder="you@example.com" />
        </div>
        <div class="field">
          <label for="message">Обратна връзка</label>
          <textarea id="message" name="message" placeholder="Всякаква обратна връзка е добре дошла!" rows="4"></textarea>
        </div>
        <button type="submit" class="submit-btn">Изпрати</button>
      </form>

      <div class="success" id="success-msg" style="display: none;">
        <p>Благодаря за предложението! Ще го разгледам скоро.</p>
      </div>
    </div>
  </section>
</Base>

<script>
  const form = document.getElementById('submit-form') as HTMLFormElement;
  const success = document.getElementById('success-msg')!;

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    // For now, just show success - can be connected to Sanity API or a form service later
    const data = new FormData(form);
    const entries = Object.fromEntries(data.entries());
    console.log('Submission:', entries);
    form.style.display = 'none';
    success.style.display = '';
  });
</script>

<style>
  .submit {
    padding: 3rem 0;
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .note {
    margin-top: 0.5rem;
    font-size: 0.8125rem;
    color: var(--grey-500);
    margin-bottom: 2rem;
  }

  .form {
    max-width: 480px;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  label {
    font-size: 0.8125rem;
    font-weight: 600;
  }

  input, textarea {
    font-family: var(--font);
    font-size: 0.875rem;
    padding: 0.625rem 0.75rem;
    border: 1px solid var(--grey-300);
    border-radius: 6px;
    background: var(--white);
    transition: border-color 0.15s;
    outline: none;
  }

  input:focus, textarea:focus {
    border-color: var(--black);
  }

  textarea {
    resize: vertical;
  }

  .submit-btn {
    font-family: var(--font);
    font-size: 0.875rem;
    font-weight: 600;
    padding: 0.75rem 1.5rem;
    background: var(--black);
    color: var(--white);
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: opacity 0.15s;
    align-self: flex-start;
  }

  .submit-btn:hover {
    opacity: 0.8;
  }

  .success p {
    font-size: 0.9375rem;
    color: var(--grey-700);
    padding: 2rem 0;
  }
</style>
