---
import Base from '../layouts/Base.astro';
import { getAgencies, getCategories, getCities } from '../lib/sanity';

const agencies = await getAgencies();
const categories = await getCategories();
const cities = await getCities();

// Count agencies per category
const catCounts: Record<string, number> = {};
for (const agency of agencies) {
  for (const cat of agency.categories || []) {
    catCounts[cat._id] = (catCounts[cat._id] || 0) + 1;
  }
}

// Count agencies per city
const cityCounts: Record<string, number> = {};
for (const agency of agencies) {
  for (const city of agency.cities || []) {
    cityCounts[city._id] = (cityCounts[city._id] || 0) + 1;
  }
}

const visibleCategories = categories.filter((c) => (catCounts[c._id] || 0) > 0);
const visibleCities = cities.filter((c) => (cityCounts[c._id] || 0) > 0);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Български Дизайн Агенции',
  url: 'https://bda.stoyanov.works',
  numberOfItems: agencies.length,
  itemListElement: agencies.map((agency, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Organization',
      name: agency.name,
      url: agency.website,
      ...(agency.image?.asset?.url && { logo: agency.image.asset.url }),
      ...(agency.description && { description: agency.description }),
    },
  })),
};
---

<Base title="Български Дизайн Агенции">
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

  <section class="hero">
    <div class="container">
      <h1>Списък с дизайн агенциите в България.</h1>
      <p class="subtitle">Собственоръчно събираме и категоризираме агенциите в списъчен и каталожен вид.</p>
      <p class="stats chrome dim">
        <span class="num">{String(agencies.length).padStart(3, '0')}</span> агенции
        <span class="sep">/</span>
        <span class="num">{String(categories.length).padStart(2, '0')}</span> категории
      </p>
    </div>
  </section>

  <section class="directory">
    <div class="container">
      <div class="controls">
        <div class="search-wrap">
          <input
            type="search"
            id="search-input"
            class="search-input"
            placeholder="Търсене на агенция..."
            autocomplete="off"
          />
        </div>
        <div class="view-toggle">
          <button class="view-btn active" data-view="grid">Каталожен вид</button>
          <button class="view-btn" data-view="list">Списъчен вид</button>
        </div>
      </div>

      <div class="filters">
        <div class="filter-group">
          <h3 class="chrome dim">Филтрация по категория</h3>
          <div class="filter-tags">
            {visibleCategories.map((cat) => (
              <button
                class="filter-tag"
                data-filter="category"
                data-value={cat.slug.current}
              >
                {cat.name} <span class="num">{catCounts[cat._id] || 0}</span>
              </button>
            ))}
          </div>
        </div>
        <div class="filter-group">
          <h3 class="chrome dim">Филтрация по град</h3>
          <div class="filter-tags">
            {visibleCities.map((city) => (
              <button
                class="filter-tag"
                data-filter="city"
                data-value={city.slug.current}
              >
                {city.name} <span class="num">{cityCounts[city._id] || 0}</span>
              </button>
            ))}
            <button type="button" class="clear-btn" id="clear-btn" hidden>Изчисти филтрите</button>
          </div>
        </div>
      </div>

      <div class="agency-grid" id="agency-grid">
        {agencies.map((agency) => {
          const imageUrl = agency.image?.asset?.url || agency.imageUrl;
          const metaParts = [
            ...(agency.categories || []).map((c) => c.name),
            ...(agency.cities || []).map((c) => c.name),
          ];
          return (
            <article
              class="agency-card"
              data-categories={(agency.categories || []).map(c => c.slug.current).join(',')}
              data-cities={(agency.cities || []).map(c => c.slug.current).join(',')}
              data-name={agency.name.toLowerCase()}
            >
              <a href={agency.website} target="_blank" rel="noopener">
                <div class={`agency-thumb${imageUrl ? '' : ' agency-thumb--empty'}`}>
                  {imageUrl ? (
                    <img
                      src={imageUrl}
                      alt={agency.name}
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <span class="agency-thumb-fallback chrome faint">{agency.name}</span>
                  )}
                </div>
                <div class="agency-info">
                  <h2 class="agency-name">{agency.name}</h2>
                  {metaParts.length > 0 && (
                    <p class="agency-meta">{metaParts.join(' · ')}</p>
                  )}
                </div>
              </a>
            </article>
          );
        })}
      </div>

      <p class="no-results" id="no-results" style="display: none;">
        Няма намерени агенции с избраните филтри.
      </p>
    </div>
  </section>
</Base>

<script>
  const grid = document.getElementById('agency-grid')!;
  const cards = grid.querySelectorAll<HTMLElement>('.agency-card');
  const noResults = document.getElementById('no-results')!;
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-tag');
  const viewBtns = document.querySelectorAll<HTMLButtonElement>('.view-btn');
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement;

  let activeCategory: string | null = null;
  let activeCity: string | null = null;
  let activeSearch = '';

  function applyFilters() {
    let visible = 0;
    cards.forEach((card) => {
      const cats = card.dataset.categories?.split(',') || [];
      const cities = card.dataset.cities?.split(',') || [];
      const name = card.dataset.name || '';

      const matchCat = !activeCategory || cats.includes(activeCategory);
      const matchCity = !activeCity || cities.includes(activeCity);
      const matchSearch = !activeSearch || name.includes(activeSearch);

      if (matchCat && matchCity && matchSearch) {
        card.style.display = '';
        visible++;
      } else {
        card.style.display = 'none';
      }
    });
    noResults.style.display = visible === 0 ? '' : 'none';
  }

  function syncURL() {
    const params = new URLSearchParams();
    if (activeCategory) params.set('category', activeCategory);
    if (activeCity) params.set('city', activeCity);
    if (activeSearch) params.set('q', searchInput.value);
    const qs = params.toString();
    const url = qs ? `${window.location.pathname}?${qs}` : window.location.pathname;
    window.history.replaceState(null, '', url);
  }

  function updateClearVisibility() {
    const hasActive = !!activeCategory || !!activeCity || !!activeSearch;
    clearBtn.hidden = !hasActive;
  }

  function setFilterFromURL() {
    const params = new URLSearchParams(window.location.search);
    const cat = params.get('category');
    const city = params.get('city');
    const q = params.get('q') || '';

    if (cat) {
      const btn = document.querySelector<HTMLButtonElement>(
        `[data-filter="category"][data-value="${CSS.escape(cat)}"]`
      );
      if (btn) {
        activeCategory = cat;
        btn.classList.add('active');
      }
    }
    if (city) {
      const btn = document.querySelector<HTMLButtonElement>(
        `[data-filter="city"][data-value="${CSS.escape(city)}"]`
      );
      if (btn) {
        activeCity = city;
        btn.classList.add('active');
      }
    }
    if (q) {
      searchInput.value = q;
      activeSearch = q.toLowerCase();
    }
  }

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const type = btn.dataset.filter;
      const value = btn.dataset.value!;

      if (type === 'category') {
        if (activeCategory === value) {
          activeCategory = null;
          btn.classList.remove('active');
        } else {
          document.querySelectorAll('[data-filter="category"]').forEach(b => b.classList.remove('active'));
          activeCategory = value;
          btn.classList.add('active');
        }
      } else {
        if (activeCity === value) {
          activeCity = null;
          btn.classList.remove('active');
        } else {
          document.querySelectorAll('[data-filter="city"]').forEach(b => b.classList.remove('active'));
          activeCity = value;
          btn.classList.add('active');
        }
      }
      applyFilters();
      syncURL();
      updateClearVisibility();
    });
  });

  searchInput.addEventListener('input', () => {
    activeSearch = searchInput.value.trim().toLowerCase();
    applyFilters();
    syncURL();
    updateClearVisibility();
  });

  clearBtn.addEventListener('click', () => {
    activeCategory = null;
    activeCity = null;
    activeSearch = '';
    document.querySelectorAll('.filter-tag.active').forEach(b => b.classList.remove('active'));
    searchInput.value = '';
    applyFilters();
    syncURL();
    updateClearVisibility();
    searchInput.focus();
  });

  viewBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      viewBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      grid.classList.toggle('list-view', btn.dataset.view === 'list');
    });
  });

  setFilterFromURL();
  applyFilters();
  updateClearVisibility();
</script>

<style>
  .hero {
    padding: 3rem 0 2rem;
    border-bottom: 1px solid var(--grey-200);
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 500;
    letter-spacing: -0.035em;
    line-height: 1.05;
    max-width: 720px;
  }

  .subtitle {
    margin-top: 1rem;
    color: var(--fg-dim);
    font-size: 1rem;
    line-height: 1.5;
    max-width: 540px;
  }

  .stats {
    margin-top: 1.25rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .stats .sep {
    opacity: 0.5;
  }

  .directory {
    padding: 2rem 0;
  }

  .controls {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .search-wrap {
    flex: 1;
    min-width: 240px;
    max-width: 360px;
  }

  .search-input {
    width: 100%;
    font-family: var(--font);
    font-size: 0.875rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--grey-300);
    border-radius: 6px;
    background: var(--white);
    outline: none;
    transition: border-color 0.15s;
  }

  .search-input:focus {
    border-color: var(--black);
  }

  .clear-btn {
    margin-left: auto;
    font-family: var(--font);
    font-size: 0.8125rem;
    padding: 0.375rem 0.75rem;
    background: none;
    border: 1px solid var(--grey-300);
    border-radius: 100px;
    color: var(--grey-700);
    cursor: pointer;
    transition: all 0.15s;
  }

  .clear-btn:hover {
    background: var(--grey-100);
    color: var(--black);
    border-color: var(--black);
  }

  .view-toggle {
    display: flex;
    gap: 0;
    border: 1px solid var(--grey-200);
    border-radius: 6px;
    overflow: hidden;
  }

  .view-btn {
    padding: 0.5rem 1rem;
    font-size: 0.8125rem;
    font-family: var(--font);
    background: var(--white);
    border: none;
    cursor: pointer;
    transition: all 0.15s;
  }

  .view-btn.active {
    background: var(--black);
    color: var(--white);
  }

  .view-btn:not(.active):hover {
    background: var(--grey-100);
  }

  .filters {
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .filter-group h3 {
    margin-bottom: 0.625rem;
  }

  .filter-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .filter-tag {
    padding: 0.375rem 0.75rem;
    font-size: 0.8125rem;
    font-family: var(--font);
    background: var(--grey-100);
    border: 1px solid var(--grey-200);
    border-radius: 100px;
    cursor: pointer;
    transition: all 0.15s;
  }

  .filter-tag:hover {
    background: var(--grey-200);
  }

  .filter-tag.active {
    background: var(--black);
    color: var(--white);
    border-color: var(--black);
  }

  .filter-tag.active .num {
    color: var(--white);
  }

  .agency-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 2.5rem 1.5rem;
  }

  @media (max-width: 1024px) {
    .agency-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 768px) {
    .agency-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .agency-card a {
    display: block;
  }

  .agency-thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 12px;
    background: var(--grey-100);
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .agency-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .agency-thumb--empty {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.25rem;
    border: 1px solid var(--border);
    background: transparent;
  }

  .agency-thumb-fallback {
    text-align: center;
    line-height: 1.4;
  }

  .agency-card:hover .agency-thumb,
  .agency-card:focus-within .agency-thumb {
    transform: translateY(-3px);
  }

  .agency-card:hover .agency-thumb img,
  .agency-card:focus-within .agency-thumb img {
    transform: scale(1.03);
  }

  .agency-info {
    margin-top: 0.875rem;
  }

  .agency-name {
    font-size: 1.0625rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--fg);
  }

  .agency-meta {
    margin-top: 0.25rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--fg-dim);
    letter-spacing: 0;
    text-transform: none;
  }

  /* List view */
  .agency-grid.list-view {
    grid-template-columns: 1fr;
    gap: 0;
  }

  .agency-grid.list-view .agency-thumb {
    display: none;
  }

  .agency-grid.list-view .agency-card a {
    display: flex;
    flex-direction: row;
    align-items: baseline;
    gap: 1.25rem;
    padding: 0.875rem 0;
    border-bottom: 1px solid var(--border);
  }

  .agency-grid.list-view .agency-info {
    margin-top: 0;
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
    flex: 1;
    flex-wrap: wrap;
  }

  .agency-grid.list-view .agency-name {
    min-width: 200px;
  }

  .agency-grid.list-view .agency-meta {
    margin-top: 0;
  }

  .no-results {
    text-align: center;
    color: var(--fg-dim);
    padding: 3rem 0;
    font-size: 0.9375rem;
  }

  @media (max-width: 640px) {
    .agency-grid {
      grid-template-columns: 1fr;
    }

    .agency-grid.list-view .agency-card a {
      flex-direction: column;
      align-items: flex-start;
    }

    .agency-grid.list-view .agency-name {
      min-width: auto;
    }
  }
</style>
